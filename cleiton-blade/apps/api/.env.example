# ==================== DATABASE ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cleiton_blade_system
DB_USER=postgres
DB_PASSWORD=postgres

# ⚠️  CHAVES SUPABASE (se usar Supabase)
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ==================== SERVER ====================
NODE_ENV=development
PORT=3000

# ==================== JWT ====================
# ⚠️  GERE CHAVES SEGURAS: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_key_min_32_chars_change_in_prod
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_secure_refresh_token_secret_key_min_32_chars
JWT_REFRESH_EXPIRATION=30d

# ==================== ADMIN ====================
ADMIN_EMAIL=admin@cleitonblade.local
ADMIN_PASSWORD=ChangeMe@12345
ADMIN_SECRET_KEY=change_this_secret_key_to_something_secure

# ==================== BCRYPT ====================
BCRYPT_ROUNDS=10

# ==================== WHATSAPP (PREPARAÇÃO) ====================
WHATSAPP_BUSINESS_API_URL=https://graph.instagram.com/v18.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCESS_TOKEN=your_access_token

# ==================== PAGINATION ====================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ==================== LOGGING ====================
LOG_LEVEL=info

# ==================== EMAIL VERIFICATION ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_or_email_password
EMAIL_FROM=noreply@cleitonblade.com
FRONTEND_URL=http://localhost:3001
EMAIL_VERIFICATION_EXPIRY=24

# ==================== RATE LIMITING ====================
RATE_LIMIT_REGISTER_PER_IP=5
RATE_LIMIT_LOGIN_PER_EMAIL=10
RATE_LIMIT_PER_IP=50
RATE_LIMIT_PER_ENDPOINT=100

# ==================== GOOGLE reCAPTCHA v3 ====================
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_DISABLED=true
